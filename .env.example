# Claude Remote configuration. Copy to `.env.local` and fill in.
#
# Vite bakes VITE_* vars into the bundle at build time, so set these BEFORE
# `npm run pack`. All three secrets/URLs here can ALSO be entered at runtime in
# the companion panel's Settings card (stored only on the device) — so a packed
# build with none of these set is still fully configurable after install.

# ─── The bridge (required) ───────────────────────────────────────────────────
# Base URL of the bridge (server/rc_bridge.py), as reachable FROM THE PHONE.
# Use a name that works from anywhere you wear the glasses — the host's
# Tailscale MagicDNS name (recommended, e.g. http://my-box.tailXXXX.ts.net:8790)
# or a LAN IP. At pack time this host is also added to the app's network
# whitelist automatically.
VITE_BRIDGE_URL=http://localhost:8790
# Shared secret guarding the bridge. The bridge reads this same file, so
# setting it once here configures both sides (an RC_BRIDGE_TOKEN env var wins).
VITE_BRIDGE_TOKEN=change-me

# Extra origins for the packed app's network whitelist (comma-separated), if
# your bridge is reachable at more than one address.
# VITE_NET_WHITELIST_EXTRA=http://192.168.1.20:8790

# ─── Polling / display (optional) ────────────────────────────────────────────
VITE_POLL_MS=4000            # active-session list refresh interval
VITE_HISTORY_LIMIT=200       # events pulled when a session is opened
# The session view scrolls natively on the glasses (no software paging). These
# size the two body windows in BYTES (the firmware caps a text container by UTF-8
# byte length, and HUD glyphs are multi-byte): the auto-following live tail, and
# the frozen history window the firmware scrolls smoothly when you swipe up.
VITE_LIVE_BODY_BYTES=320     # live-tail size in bytes (~one screen of newest output)
VITE_HISTORY_BYTES=900       # history window in bytes (a few screens; < the ~1000B cap)
VITE_MAX_LIST_ROWS=12        # sessions/menu rows per list screen
VITE_INPUT_CLIP_CHARS=140    # tool/permission input clip on the HUD

# One-tap canned messages for the Compose menu (JSON array of {label,text}).
# VITE_QUICK_SENDS=[{"label":"Continue","text":"continue"},{"label":"Yes","text":"yes"}]

# ─── Voice dictation (optional; needs a Deepgram key) ────────────────────────
# Leave the key blank to disable voice input entirely (quick-actions still work).
# Free-tier keys from https://console.deepgram.com work fine.
VITE_DEEPGRAM_API_KEY=
VITE_DEEPGRAM_MODEL=nova-3
VITE_STT_LANGUAGE=en
VITE_VOICE_ENABLED=true
VITE_MIC_SILENCE_TIMEOUT_MS=8000
